{% comment %}
  Renders the time label, title and description of a single timeline step block.
  Required: block (section block of type "step").
{% endcomment %}

{% if block.settings.time_label != blank %}
  <p class="timeline-steps__time">{{ block.settings.time_label }}</p>
{% endif %}

{% if block.settings.title != blank %}
  <h3 class="timeline-steps__title">{{ block.settings.title }}</h3>
{% endif %}

{% if block.settings.description != blank %}
  <p class="timeline-steps__description">{{ block.settings.description }}</p>
{% endif %}
