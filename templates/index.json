    "dlh_faq": {
      "type": "dlh-faq",
      "blocks": {
        "faq_1": {
          "type": "faq_item",
          "settings": {
            "question": "How do I get picked up from my hotel?",
            "answer": "A Bedouin-trained driver will arrive at your hotel lobby 15 minutes before the scheduled time, in a clearly marked Toyota Land Cruiser. You'll receive their name and photo by WhatsApp the day before."
          }
        },
        "faq_2": {
          "type": "faq_item",
          "settings": {
            "question": "Is the desert safari safe for kids and seniors?",
            "answer": "Yes. We host guests from age 3 to 80+. Dune bashing is optional — families with young children or seniors can skip it and join us directly at the camp. Every vehicle has seatbelts, a trained driver, and first-aid equipment."
          }
        },
        "faq_3": {
          "type": "faq_item",
          "settings": {
            "question": "What should I wear?",
            "answer": "Loose, comfortable clothing and closed-toe shoes for daytime. Light layers for evening — the desert cools sharply after sunset. Cultural dress (shoulders and knees covered) is recommended for the camp."
          }
        },
        "faq_4": {
          "type": "faq_item",
          "settings": {
            "question": "Can I book a fully private experience?",
            "answer": "Absolutely. Our Private Overnight Camp and Private Heritage Trek are bookable year-round. For bespoke multi-day itineraries, reach out via WhatsApp and we'll design it with you."
          }
        },
        "faq_5": {
          "type": "faq_item",
          "settings": {
            "question": "What is your cancellation policy?",
            "answer": "Free cancellation up to 24 hours before your experience. No-questions-asked refund to your original payment method within 3 business days."
          }
        },
        "faq_6": {
          "type": "faq_item",
          "settings": {
            "question": "Is the food vegetarian/halal/allergy-friendly?",
            "answer": "Our BBQ buffet includes halal meats, full vegetarian and vegan options, and gluten-free mains. Please flag allergies at booking and we'll confirm arrangements with the camp chef."
          }
        }
      },
