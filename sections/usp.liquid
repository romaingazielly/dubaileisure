{{ 'usp.css' | asset_url | stylesheet_tag: preload: true }}

{%- liquid
  assign cols_sm = section.settings.columns_mobile
  assign cols_md = section.settings.columns_tablet
  assign cols_lg = section.settings.columns_desktop
-%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} usp-band spacing-style"
  style="
    {% render 'spacing-style', settings: section.settings %}
    --usp-max-width: {{ section.settings.max_width }}px;
    --usp-gap: {{ section.settings.gap }}px;
    --usp-radius: {{ section.settings.cell_radius }}px;
    --usp-logo-h: {{ section.settings.logo_max_height }}px;
    --usp-cols-sm: {{ cols_sm }};
    --usp-cols-md: {{ cols_md }};
    --usp-cols-lg: {{ cols_lg }};
  "
>
  <div class="usp-band__inner" {{ section.shopify_attributes }}>
    {% if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.subheading != blank %}
      <header class="usp-band__header">
        {% if section.settings.eyebrow != blank %}
          <p class="usp-band__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="usp-band__heading h3">{{ section.settings.heading | escape }}</h2>
        {% endif %}
        {% if section.settings.subheading != blank %}
          <p class="usp-band__subheading">{{ section.settings.subheading | escape }}</p>
        {% endif %}
      </header>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <ul class="usp-band__grid" role="list">
        {% for block in section.blocks %}
          <li class="usp-cell" {{ block.shopify_attributes }}>
            {% liquid
              assign has_link = false
              if block.settings.link != blank
                assign has_link = true
              endif
              assign logo = block.settings.logo
              assign title = block.settings.heading
              assign cap = block.settings.caption
            %}

            {% if has_link %}
              <a
                href="{{ block.settings.link }}"
                class="usp-cell__link"
                {% if block.settings.open_new_tab %}
                  target="_blank" rel="noopener noreferrer"
                {% endif %}
              >
                {% render 'usp-cell', logo: logo, title: title, caption: cap, placeholder_seed: title %}
              </a>
            {% else %}
              <div class="usp-cell__inner">
                {% render 'usp-cell', logo: logo, title: title, caption: cap, placeholder_seed: title %}
              </div>
            {% endif %}
          </li>
        {% endfor %}
      </ul>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "USP",
  "tag": "section",
  "class": "section-wrapper",
  "max_blocks": 8,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Sur-titre",
      "default": "WHY TRAVEL WITH US"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Trust built for families & partners"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Sous-titre",
      "default": "Badges, certifications and promises — up to 8 USP cells."
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Largeur max du contenu",
      "min": 900,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Espacement entre cellules",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "cell_radius",
      "label": "Arrondi des cellules",
      "min": 8,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "logo_max_height",
      "label": "Hauteur max des logos",
      "min": 28,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 44
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Colonnes (mobile)",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "columns_tablet",
      "label": "Colonnes (tablette)",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" }
      ],
      "default": "3"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Colonnes (desktop)",
      "options": [
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "4"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Schéma de couleurs",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Largeur de section",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Pleine largeur" }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "Espacements"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Padding haut",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Padding bas",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "usp_cell",
      "name": "Cell",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo ou icône"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Titre",
          "default": "Family safe"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Légende",
          "default": "Ages 3 to 80+"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Lien (optionnel)"
        },
        {
          "type": "checkbox",
          "id": "open_new_tab",
          "label": "Ouvrir le lien dans un nouvel onglet",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "USP",
      "category": "t:categories.storytelling",
      "blocks": [
        {
          "type": "usp_cell",
          "settings": {
            "heading": "Family safe",
            "caption": "Ages 3 to 80+"
          }
        },
        {
          "type": "usp_cell",
          "settings": {
            "heading": "Eco-conscious",
            "caption": "Sustainable tourism"
          }
        },
        {
          "type": "usp_cell",
          "settings": {
            "heading": "Premium quality",
            "caption": "Top-tier hospitality"
          }
        },
        {
          "type": "usp_cell",
          "settings": {
            "heading": "ISO certified",
            "caption": "Quality management"
          }
        }
      ]
    }
  ]
}
{% endschema %}
