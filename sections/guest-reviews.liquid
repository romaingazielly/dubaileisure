{{ 'guest-reviews.css' | asset_url | stylesheet_tag }}

{% liquid
  assign total_blocks = section.blocks.size
%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} guest-reviews spacing-style{% if section.settings.pause_on_hover %} guest-reviews--pause-hover{% endif %}"
  style="
    {% render 'spacing-style', settings: section.settings %}
    --guest-review-card-w: {{ section.settings.card_width }}px;
    --guest-review-gap: {{ section.settings.card_gap }}px;
    --guest-review-duration: {{ section.settings.scroll_seconds }}s;
  "
  {% if section.settings.section_id != blank %}
    id="{{ section.settings.section_id | handle }}"
  {% endif %}
>
  <div class="guest-reviews__intro-shell page-width-content" {{ section.shopify_attributes }}>
    {% if section.settings.eyebrow != blank
      or section.settings.heading != blank
      or section.settings.heading_accent != blank
      or section.settings.subheading != blank
    %}
      <header class="guest-reviews__intro">
        {% if section.settings.eyebrow != blank %}
          <p class="guest-reviews__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {% endif %}
        {% if section.settings.heading != blank
          or section.settings.heading_accent != blank
        %}
          <div class="guest-reviews__divider" aria-hidden="true"></div>
          <h2 class="guest-reviews__heading h2">
            {% if section.settings.heading != blank %}
              {{ section.settings.heading | escape }}
            {% endif %}
            {% if section.settings.heading_accent != blank %}
              <span class="guest-reviews__heading-accent"> {{ section.settings.heading_accent | escape }}</span>
            {% endif %}
          </h2>
        {% endif %}
        {% if section.settings.subheading != blank %}
          <p class="guest-reviews__sub">{{ section.settings.subheading | escape }}</p>
        {% endif %}
      </header>
    {% endif %}

    {% if total_blocks == 0 and request.design_mode %}
      <p class="guest-reviews__empty">Add “Guest review” blocks below.</p>
    {% endif %}
  </div>

  {% if total_blocks > 0 %}
    {% liquid
      assign reviews_aria = section.settings.heading | append: ' ' | append: section.settings.heading_accent | strip
      if reviews_aria == blank
        assign reviews_aria = 'Guest reviews'
      endif
    %}
    <div class="guest-reviews__track-wrap">
      <div
        class="guest-reviews__track{% unless request.design_mode %} guest-reviews__track--animate{% endunless %}"
        role="region"
        aria-label="{{ reviews_aria | escape }}"
        data-guest-reviews-track
      >
        <div class="guest-reviews__marquee-row" data-guest-reviews-row>
          {% content_for 'blocks' %}
        </div>
      </div>
    </div>

    {%- comment -%} Seamless loop : clone JS de la rangée, uniquement hors éditeur {%- endcomment -%}
    {% unless request.design_mode %}
      <script>
        (() => {
          const track = document.querySelector('[data-guest-reviews-track]');
          if (!track) return;
          const row = track.querySelector('[data-guest-reviews-row]');
          if (!row || row.children.length === 0) return;
          const clone = row.cloneNode(true);
          clone.classList.add('guest-reviews__marquee-row--clone');
          clone.setAttribute('aria-hidden', 'true');
          clone.removeAttribute('data-guest-reviews-row');
          track.appendChild(clone);
        })();
      </script>
    {% endunless %}
  {% endif %}
</div>

{% schema %}
{
  "name": "Guest reviews (marquee)",
  "tag": "section",
  "class": "section-wrapper",
  "max_blocks": 20,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "section_id",
      "label": "Section HTML id (anchor)",
      "info": "e.g. reviews for links like #reviews",
      "default": "reviews"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Guest Stories"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Voices from the"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Heading accent",
      "default": "Dunes"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Over 15,000 guests have made memories in the desert. Here's what they said."
    },
    {
      "type": "range",
      "id": "card_width",
      "min": 260,
      "max": 420,
      "step": 10,
      "unit": "px",
      "label": "Card width",
      "default": 340
    },
    {
      "type": "range",
      "id": "card_gap",
      "min": 8,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Gap between cards",
      "default": 24
    },
    {
      "type": "range",
      "id": "scroll_seconds",
      "min": 15,
      "max": 80,
      "step": 1,
      "unit": "s",
      "label": "Loop duration",
      "default": 35
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on hover",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "full-width"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "guest_review"
    }
  ],
  "presets": [
    {
      "name": "Guest reviews (marquee)",
      "category": "t:categories.storytelling",
      "blocks": [
        {
          "type": "guest_review",
          "settings": {
            "quote": "Absolutely spectacular evening. The dune bashing was thrilling, the buffet was outstanding, and the fire show had our kids speechless. Worth every dirham.",
            "author": "James M.",
            "meta": "London, UK · TripAdvisor"
          }
        },
        {
          "type": "guest_review",
          "settings": {
            "quote": "The sunrise safari was magical — cool breeze, golden dunes, and Arabic coffee at dawn. Our guide was incredibly knowledgeable about Bedouin culture.",
            "author": "Sara A.",
            "meta": "Paris, France · Google"
          }
        },
        {
          "type": "guest_review",
          "settings": {
            "quote": "Took the dune buggy add-on and it was the highlight of our Dubai trip. Professional, safe, and outrageously fun. We're coming back next year!",
            "author": "Ravi C.",
            "meta": "Mumbai, India · TripAdvisor"
          }
        },
        {
          "type": "guest_review",
          "settings": {
            "quote": "Seamless from pickup to drop-off. The henna artist was amazing with our daughters. The belly dance show was mesmerising. Highly, highly recommend.",
            "author": "Kim L.",
            "meta": "Sydney, Australia · Google"
          }
        },
        {
          "type": "guest_review",
          "settings": {
            "quote": "We're a family of five including grandparents. Everyone had an incredible time — the team was thoughtful, attentive, and genuinely warm. True Arabian hospitality.",
            "author": "Thomas P.",
            "meta": "New York, USA · TripAdvisor"
          }
        }
      ]
    }
  ]
}
{% endschema %}
