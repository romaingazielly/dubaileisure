{{ 'dlh-pdp-vehicle.css' | asset_url | stylesheet_tag }}
{{ 'dlh-vehicle-sticky-add-to-cart.css' | asset_url | stylesheet_tag }}

<svg xmlns="http://www.w3.org/2000/svg" style="display:none">
  <symbol id="dlh-ico-star" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></symbol>
  <symbol id="dlh-ico-chevl" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></symbol>
  <symbol id="dlh-ico-chevr" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></symbol>
  <symbol id="dlh-ico-chevd" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></symbol>
  <symbol id="dlh-ico-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></symbol>
  <symbol id="dlh-ico-plus" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></symbol>
  <symbol id="dlh-ico-minus" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14"/></symbol>
  <symbol id="dlh-ico-heart" viewBox="0 0 24 24"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.7l-1-1.1a5.5 5.5 0 1 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8z"/></symbol>
  <symbol id="dlh-ico-cal" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M3 10h18M8 3v4M16 3v4"/></symbol>
  <symbol id="dlh-ico-zoom" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3h6M3 3v6M21 21h-6M21 21v-6M21 3h-6M21 3v6M3 21h6M3 21v-6"/></symbol>
  <symbol id="dlh-ico-play" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></symbol>
  <symbol id="dlh-ico-shield" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2l8 3v6c0 5-3.5 9-8 11-4.5-2-8-6-8-11V5l8-3z"/><path d="M9 12l2 2 4-4"/></symbol>
  <symbol id="dlh-ico-bolt" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"><path d="M13 2L4 14h7l-1 8 9-12h-7l1-8z"/></symbol>
  <symbol id="dlh-ico-refund" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 12a9 9 0 1 0 3-6.7M3 4v5h5"/></symbol>
  <symbol id="dlh-ico-mobile" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="7" y="2" width="10" height="20" rx="2"/><path d="M11 18h2"/></symbol>
  <symbol id="dlh-ico-cart" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 3h2l2.7 12.4a2 2 0 0 0 2 1.6h8.6a2 2 0 0 0 2-1.6L22 7H6"/><circle cx="9" cy="21" r="1.5"/><circle cx="18" cy="21" r="1.5"/></symbol>
  <symbol id="dlh-ico-x" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></symbol>
  <symbol id="dlh-ico-wa" viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 14.4c-.3-.1-1.7-.8-2-1-.3-.1-.4-.1-.6.1l-.9 1.1c-.2.2-.3.2-.6.1-.3-.1-1.3-.5-2.4-1.5-.9-.8-1.5-1.8-1.7-2.1-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5-.1-.1-.6-1.5-.9-2-.2-.5-.5-.5-.6-.5H7.8c-.2 0-.5.1-.7.3-.3.3-1 1-1 2.4 0 1.4 1 2.7 1.2 2.9.1.2 2 3 4.8 4.2.7.3 1.2.5 1.6.6.7.2 1.3.2 1.8.1.5-.1 1.7-.7 1.9-1.4.2-.7.2-1.2.2-1.4-.1-.1-.3-.2-.6-.3zM12 2a10 10 0 0 0-8.5 15.2L2 22l4.9-1.4A10 10 0 1 0 12 2z"/></symbol>
  <symbol id="dlh-ico-truck" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 3h15v13H1zM16 8h4l3 3v5h-7"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></symbol>
  <symbol id="dlh-ico-camera" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M23 19V8a2 2 0 0 0-2-2h-3.2l-1.8-3h-8l-1.8 3H3a2 2 0 0 0-2 2v11a2 2 0 0 0 2 2h18a2 2 0 0 0 2-2z"/><circle cx="12" cy="13" r="4"/></symbol>
  <symbol id="dlh-ico-fire" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2s4 4 4 8a4 4 0 0 1-8 0c0-1 .5-2 1-3-1 0-3 1-3 4a6 6 0 0 0 12 0c0-5-6-9-6-9z"/></symbol>
</svg>

<div class="dlh-pv__grid" data-section-id="{{ section.id }}">

  <div class="dlh-pv__left">
  {%- assign dlh_media_count = product.media.size -%}
  <dlh-pdp-gallery class="dlh-pv__gal{% if dlh_media_count <= 1 %} dlh-pv__gal--single{% endif %}">
    {%- if dlh_media_count > 1 -%}
      <div class="dlh-pv__thumbs">
        {%- for media in product.media -%}
          <button class="dlh-pv__thumb {% if forloop.first %}is-active{% endif %}" data-thumb aria-label="View media {{ forloop.index }}">
            {%- if media.media_type == 'image' -%}
              <img src="{{ media | image_url: width: 200 }}" alt="{{ media.alt | escape }}" loading="lazy" width="96" height="72">
            {%- elsif media.media_type == 'video' or media.media_type == 'external_video' -%}
              {%- if media.preview_image -%}
                <img src="{{ media.preview_image | image_url: width: 200 }}" alt="{{ media.alt | escape }}" loading="lazy" width="96" height="72">
              {%- endif -%}
              <span class="dlh-pv__thumb-play"><svg width="20" height="20"><use href="#dlh-ico-play"/></svg></span>
            {%- endif -%}
          </button>
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div class="dlh-pv__main">
      <nav class="dlh-pv__crumb dlh-pv__crumb--on-gallery" aria-label="Breadcrumb">
        <a href="{{ routes.root_url }}">{{ 'accessibility.home' | t | default: 'Home' }}</a>
        <span class="dlh-pv__crumb-sep">/</span>
        {%- if product.collections.size > 0 -%}
          {%- assign col = product.collections.first -%}
          <a href="{{ col.url }}">{{ col.title }}</a>
          <span class="dlh-pv__crumb-sep">/</span>
        {%- endif -%}
        <span class="dlh-pv__crumb-here">{{ product.title }}</span>
      </nav>

      {%- for media in product.media -%}
        <div class="dlh-pv__slide {% if forloop.first %}is-active{% endif %}" data-slide>
          {%- if media.media_type == 'image' -%}
            <img
              src="{{ media | image_url: width: 1200 }}"
              alt="{{ media.alt | escape }}"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              width="{{ media.width }}"
              height="{{ media.height }}"
            >
          {%- elsif media.media_type == 'video' -%}
            {{ media | video_tag: autoplay: false, loop: true, muted: true, controls: true, class: 'dlh-pv__video' }}
          {%- elsif media.media_type == 'external_video' -%}
            {{ media | external_video_tag }}
          {%- endif -%}
        </div>
      {%- endfor -%}

      <div class="dlh-pv__tags">
        {%- for tag in product.tags -%}
          {%- if tag contains 'badge:' -%}
            {%- assign badge_text = tag | remove: 'badge:' | strip -%}
            <span class="dlh-pv__tag">{{ badge_text }}</span>
          {%- endif -%}
        {%- endfor -%}
        {%- if product.compare_at_price > product.price -%}
          {%- assign save_pct = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
          <span class="dlh-pv__tag dlh-pv__tag--dark">-{{ save_pct }}%</span>
        {%- endif -%}
      </div>

      <button class="dlh-pv__fav" data-fav aria-label="Save to wishlist">
        <svg width="20" height="20"><use href="#dlh-ico-heart"/></svg>
      </button>

      {%- if dlh_media_count > 1 -%}
        <div class="dlh-pv__arrows">
          <button class="dlh-pv__arrow" data-prev aria-label="Previous">
            <svg width="18" height="18"><use href="#dlh-ico-chevl"/></svg>
          </button>
          <button class="dlh-pv__arrow" data-next aria-label="Next">
            <svg width="18" height="18"><use href="#dlh-ico-chevr"/></svg>
          </button>
        </div>
      {%- endif -%}

      {%- if dlh_media_count > 1 -%}
        <div class="dlh-pv__dots">
          {%- for media in product.media -%}
            <button class="dlh-pv__dot {% if forloop.first %}is-active{% endif %}" data-dot aria-label="Slide {{ forloop.index }}"></button>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- if dlh_media_count > 1 -%}
        <button class="dlh-pv__zoom">
          <svg width="14" height="14"><use href="#dlh-ico-zoom"/></svg>
          View all {{ product.media.size }}
        </button>
      {%- endif -%}
    </div>
  </dlh-pdp-gallery>

  {%- if section.settings.show_trust_bar -%}
    <div class="dlh-pv__trust">
      {%- for block in section.blocks -%}
        {%- if block.type == 'trust_item' -%}
          <div class="dlh-pv__trust-item" {{ block.shopify_attributes }}>
            <svg width="18" height="18"><use href="#dlh-ico-{{ block.settings.icon }}"/></svg>
            {{ block.settings.label }}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}
  </div>

  <div class="dlh-pv__buy">

    <div class="dlh-pv__head">
      {%- if section.settings.category_text != blank -%}
        <p class="dlh-pv__cat">{{ section.settings.category_text }}</p>
      {%- endif -%}

      <h1 class="dlh-pv__title">
        {{ product.title }}
        {%- if section.settings.title_accent != blank -%}
          <span class="dlh-pv__title-accent">{{ section.settings.title_accent }}</span>
        {%- endif -%}
      </h1>

      {%- if section.settings.rating != blank -%}
        <div class="dlh-pv__rating">
          <span class="dlh-pv__stars">
            {%- for i in (1..5) -%}
              <svg width="14" height="14" fill="#f2a104"><use href="#dlh-ico-star"/></svg>
            {%- endfor -%}
          </span>
          <b>{{ section.settings.rating }}</b>
          <a href="#reviews">({{ section.settings.review_count }} reviews)</a>
        </div>
      {%- endif -%}
    </div>

    <div class="dlh-pv__price-wrap">
      <div class="dlh-pv__price">
        <span class="dlh-pv__price-now" data-price-now>{{ product.selected_or_first_available_variant.price | money }}</span>
        {%- if product.compare_at_price > product.price -%}
          <span class="dlh-pv__price-was" data-price-was>{{ product.compare_at_price | money }}</span>
          {%- assign save_pct = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
          <span class="dlh-pv__price-save">Save {{ save_pct }}%</span>
        {%- endif -%}
      </div>
      {%- if section.settings.price_unit != blank -%}
        <div class="dlh-pv__price-unit">{{ section.settings.price_unit }}</div>
      {%- endif -%}
    </div>

    {%- if section.settings.urgency_text != blank -%}
      <div class="dlh-pv__urgency">
        <span class="dlh-pv__pulse"></span>
        <span>{{ section.settings.urgency_text }}</span>
      </div>
    {%- endif -%}

    <div class="dlh-pv__buy-form buy-buttons-block">
    <product-form-component
      data-section-id="{{ section.id }}"
      data-product-id="{{ product.id }}"
      data-product-url="{{ product.url }}"
      on:submit="/handleSubmit"
      data-quantity-default="{% if product.selected_or_first_available_variant.quantity_rule.min %}{{ product.selected_or_first_available_variant.quantity_rule.min }}{% else %}1{% endif %}"
      data-quantity-error-max="{{ 'products.product.quantity_error_max' | t }}"
    >
      <div
        class="visually-hidden"
        aria-live="assertive"
        role="status"
        aria-atomic="true"
        ref="liveRegion"
      ></div>
      {%- form 'product', product, id: 'dlh-pdp-form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
      <input type="hidden" name="id" ref="variantId" value="{{ product.selected_or_first_available_variant.id }}">

      {%- if product.has_only_default_variant == false -%}
        <dlh-pdp-variant-picker
          data-variants='{{ product.variants | json }}'
          data-currency="{{ cart.currency.iso_code }}"
        >
          {%- for option in product.options_with_values -%}
            <div class="dlh-pv__field">
              <div class="dlh-pv__label">
                <span>{{ option.name }}</span>
                {%- if forloop.first -%}
                  <span class="dlh-pv__hint">{{ section.settings.option1_hint | default: '' }}</span>
                {%- endif -%}
              </div>

              {%- if forloop.first -%}
                <div class="dlh-pv__variants">
                  {%- for value in option.values -%}
                    <button
                      type="button"
                      class="dlh-pv__variant {% if option.selected_value == value %}is-active{% endif %}"
                      data-option
                      data-group="option1"
                      data-value="{{ value | escape }}"
                    >
                      <span class="dlh-pv__variant-check"><svg width="10" height="10"><use href="#dlh-ico-check"/></svg></span>
                      <span class="dlh-pv__variant-name">{{ value }}</span>
                    </button>
                  {%- endfor -%}
                </div>

              {%- else -%}
                <div class="dlh-pv__pills">
                  {%- for value in option.values -%}
                    <button
                      type="button"
                      class="dlh-pv__pill {% if option.selected_value == value %}is-active{% endif %}"
                      data-option
                      data-group="option{{ forloop.parentloop.index }}"
                      data-value="{{ value | escape }}"
                    >
                      {{ value }}
                    </button>
                  {%- endfor -%}
                </div>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </dlh-pdp-variant-picker>
      {%- endif -%}

      <div class="dlh-pv__field">
        <div class="dlh-pv__label">
          <span>{{ section.settings.qty_label | default: 'Quantity' }}</span>
          <span class="dlh-pv__hint">{{ section.settings.qty_hint | default: 'How many to add' }}</span>
        </div>
        <dlh-pdp-stepper class="dlh-pv__stepper" data-max="8">
          <div class="dlh-pv__stepper-info">
            <div class="dlh-pv__stepper-mainline">
              <b class="dlh-pv__stepper-qtynum" data-qty-display>1</b>
              {%- if product.has_only_default_variant == false -%}
                <div class="dlh-pv__stepper-recap" data-stepper-recap>
                  <p class="dlh-pv__stepper-recap-line">
                    {%- for option in product.options_with_values -%}
                      {%- if forloop.first -%}
                        <span data-stepper-bind="0">{{ option.selected_value | escape }}</span>
                        {%- if section.settings.qty_recap_first_suffix != blank -%}
                          <span class="dlh-pv__stepper-suffix">{{ section.settings.qty_recap_first_suffix | escape }}</span>
                        {%- endif -%}
                      {%- else -%}
                        <span class="dlh-pv__stepper-sep" aria-hidden="true"> - </span>
                        <span data-stepper-bind="{{ forloop.index0 }}">{{ option.selected_value | escape }}</span>
                      {%- endif -%}
                    {%- endfor -%}
                  </p>
                </div>
              {%- endif -%}
            </div>
            {%- if section.settings.qty_sub != blank -%}
              <small class="dlh-pv__stepper-optional-sub">{{ section.settings.qty_sub }}</small>
            {%- endif -%}
          </div>
          <div class="dlh-pv__stepper-ctrls">
            <button type="button" class="dlh-pv__stepper-btn" data-minus disabled>
              <svg width="14" height="14"><use href="#dlh-ico-minus"/></svg>
            </button>
            <input type="hidden" name="quantity" value="1">
            <span class="dlh-pv__stepper-val">1</span>
            <button type="button" class="dlh-pv__stepper-btn" data-plus>
              <svg width="14" height="14"><use href="#dlh-ico-plus"/></svg>
            </button>
          </div>
        </dlh-pdp-stepper>
      </div>

      {%- if section.settings.show_date_picker -%}
        <dlh-pdp-calendar class="dlh-pv__field dlh-pv__date-field">
          <div class="dlh-pv__label">
            <span>Pick your date & time</span>
            <span class="dlh-pv__hint">Live availability</span>
          </div>

          <button type="button" class="dlh-pv__date-trigger" data-cal-trigger>
            <span class="dlh-pv__date-val">
              <svg width="18" height="18"><use href="#dlh-ico-cal"/></svg>
              <span class="dlh-pv__date-txt dlh-pv__date-txt--placeholder" data-date-label>Select a date</span>
            </span>
            <svg class="dlh-pv__date-caret" width="14" height="14"><use href="#dlh-ico-chevd"/></svg>
          </button>

          <input type="hidden" name="properties[Date]" value="">

          <div class="dlh-pv__cal" data-cal-popup>
            <div class="dlh-pv__cal-head">
              <span class="dlh-pv__cal-title" data-cal-month-title></span>
              <div class="dlh-pv__cal-nav">
                <button type="button" data-cal-prev><svg width="14" height="14"><use href="#dlh-ico-chevl"/></svg></button>
                <button type="button" data-cal-next><svg width="14" height="14"><use href="#dlh-ico-chevr"/></svg></button>
              </div>
            </div>
            <div class="dlh-pv__cal-grid">
              {%- assign dow = 'S,M,T,W,T,F,S' | split: ',' -%}
              {%- for d in dow -%}
                <div class="dlh-pv__cal-dow">{{ d }}</div>
              {%- endfor -%}
              <div data-cal-days style="display:contents"></div>
            </div>
          </div>

          <dlh-pdp-slots class="dlh-pv__slots" data-slots style="display:none">
            <input type="hidden" name="properties[Time]" value="">
            {%- for block in section.blocks -%}
              {%- if block.type == 'time_slot' -%}
                <button
                  type="button"
                  class="dlh-pv__slot"
                  data-slot="{{ block.settings.time }}"
                  {% if block.settings.sold_out %}disabled{% endif %}
                  {{ block.shopify_attributes }}
                >
                  {{ block.settings.time }}
                  <span class="dlh-pv__slot-left">
                    {%- if block.settings.sold_out -%}
                      Sold out
                    {%- else -%}
                      {{ block.settings.spots_left }} left
                    {%- endif -%}
                  </span>
                </button>
              {%- endif -%}
            {%- endfor -%}
          </dlh-pdp-slots>
        </dlh-pdp-calendar>
      {%- endif -%}

      {%- assign addon_blocks = section.blocks | where: 'type', 'addon' -%}
      {%- if addon_blocks.size > 0 -%}
        <div class="dlh-pv__field" data-addon-field hidden aria-hidden="true">
          <div class="dlh-pv__label">
            <span>{{ section.settings.addons_label | default: 'Add to your experience' }}</span>
            <span class="dlh-pv__hint">Optional</span>
          </div>
          <dlh-pdp-addons class="dlh-pv__addons">
            {%- for block in addon_blocks -%}
              <label class="dlh-pv__addon" data-addon {{ block.shopify_attributes }}>
                <input type="checkbox" name="properties[{{ block.settings.name }}]" value="Yes">
                <span class="dlh-pv__addon-check">
                  <svg width="12" height="12"><use href="#dlh-ico-check"/></svg>
                </span>
                <span class="dlh-pv__addon-body">
                  <span class="dlh-pv__addon-title">
                    <b>{{ block.settings.name }}</b>
                    <span class="dlh-pv__addon-price">+{{ block.settings.price_label }}</span>
                  </span>
                  {%- if block.settings.description != blank -%}
                    <span class="dlh-pv__addon-desc">{{ block.settings.description }}</span>
                  {%- endif -%}
                </span>
              </label>
            {%- endfor -%}
          </dlh-pdp-addons>
        </div>
      {%- endif -%}

      <div class="dlh-pv__total">
        <span class="dlh-pv__total-label">Total</span>
        <span
          class="dlh-pv__total-val"
          data-total-val
          data-unit-price-cents="{{ product.selected_or_first_available_variant.price }}"
          data-currency="{{ cart.currency.iso_code }}"
        >
          {{ product.selected_or_first_available_variant.price | money }}
        </span>
      </div>

      {%- liquid
        assign dlh_pfv = product.selected_or_first_available_variant
        assign dlh_product_variant_media = dlh_pfv.featured_media.preview_image | image_url: width: 100
        if dlh_pfv.featured_media.preview_image == blank
          assign dlh_product_variant_media = product.featured_media.preview_image | image_url: width: 100
        endif
      -%}
      <div class="dlh-pv__ctas">
        <add-to-cart-component
          class="dlh-pv__add-to-cart"
          ref="addToCartButtonContainer"
          data-product-variant-media="{{ dlh_product_variant_media }}"
          data-add-to-cart-animation="{% if settings.add_to_cart_animation %}true{% else %}false{% endif %}"
        >
          <button
            type="submit"
            name="add"
            ref="addToCartButton"
            on:click="/handleClick"
            class="dlh-pv__cta dlh-pv__cta--primary"
            {% unless dlh_pfv.available %}
              disabled
            {% endunless %}
          >
            <span class="add-to-cart-text">
              {%- if dlh_pfv.available -%}
                <span aria-hidden="true" class="dlh-pv__cta-add-icon">
                  <svg width="18" height="18"><use href="#dlh-ico-cart"/></svg>
                </span>
              {%- endif -%}
              <span class="add-to-cart-text__content">
                <span>
                  {%- if dlh_pfv.available -%}
                    Add to cart
                  {%- elsif dlh_pfv == blank -%}
                    {{ 'products.product.unavailable' | t }}
                  {%- else -%}
                    {{ 'products.product.sold_out' | t }}
                  {%- endif -%}
                </span>
              </span>
            </span>
            <span class="add-to-cart__added" aria-hidden="true">
              <span class="svg-wrapper add-to-cart__added-icon">
                {{- 'icon-checkmark-burst.svg' | inline_asset_content -}}
              </span>
            </span>
          </button>
        </add-to-cart-component>

        {%- if section.settings.show_buy_now -%}
          <button type="submit" name="add" class="dlh-pv__cta dlh-pv__cta--secondary"
            onclick="this.closest('form').querySelector('[name=return_to]')?.remove(); this.closest('form').insertAdjacentHTML('beforeend','<input type=hidden name=return_to value=/checkout>'); this.closest('form').submit();"
          >
            Buy it now
          </button>
        {%- endif -%}

        {%- if section.settings.whatsapp_url != blank -%}
          <a href="{{ section.settings.whatsapp_url }}" class="dlh-pv__cta dlh-pv__cta--ghost" target="_blank" rel="noopener">
            <svg width="18" height="18"><use href="#dlh-ico-wa"/></svg>
            Book via WhatsApp instead
          </a>
        {%- endif -%}
      </div>
    {%- endform -%}
    </product-form-component>
    </div>

    {%- if section.settings.show_reassurance -%}
      <div class="dlh-pv__reass">
        {%- for block in section.blocks -%}
          {%- if block.type == 'reassurance' -%}
            <span class="dlh-pv__reass-item" {{ block.shopify_attributes }}>
              <svg width="14" height="14"><use href="#dlh-ico-check"/></svg>
              {{ block.settings.text }}
            </span>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- assign ticker_blocks = section.blocks | where: 'type', 'ticker_msg' -%}
    {%- if ticker_blocks.size > 0 -%}
      <dlh-pdp-ticker class="dlh-pv__ticker">
        <span class="dlh-pv__ticker-dot"></span>
        {%- for block in ticker_blocks -%}
          <span class="dlh-pv__ticker-text" data-ticker-msg {% if forloop.first == false %}style="display:none"{% endif %} {{ block.shopify_attributes }}>
            <b>{{ block.settings.name }}</b> {{ block.settings.detail }} · <span style="color:var(--fg-muted)">{{ block.settings.ago }}</span>
          </span>
        {%- endfor -%}
      </dlh-pdp-ticker>
    {%- endif -%}
  </div>

</div>

{%- if section.settings.enable_sticky_add_to_cart -%}
  {%- render 'dlh-vehicle-sticky-add-to-cart', product: product -%}
{%- endif -%}

{%- if section.settings.whatsapp_url != blank -%}
  <a href="{{ section.settings.whatsapp_url }}" class="dlh-pv__wa" aria-label="WhatsApp" target="_blank" rel="noopener">
    <svg width="28" height="28"><use href="#dlh-ico-wa"/></svg>
  </a>
{%- endif -%}

<dlh-pdp-toast class="dlh-pv__toast">
  <svg width="20" height="20"><use href="#dlh-ico-check"/></svg>
  <span data-toast-text></span>
</dlh-pdp-toast>

<script src="{{ 'dlh-pdp-vehicle.js' | asset_url }}" defer="defer"></script>

