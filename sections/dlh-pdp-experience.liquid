{{ 'dlh-pdp-experience.css' | asset_url | stylesheet_tag }}

{%- comment -%} ── Description + What's Included (cream bg) ── {%- endcomment -%}
<section class="dlh-pe" {{ section.shopify_attributes }}>
  <div class="dlh-pe__inner">
    {%- if section.settings.desc_eyebrow != blank -%}
      <p class="dlh-pe__eyebrow">{{ section.settings.desc_eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.desc_heading != blank or section.settings.desc_heading_accent != blank -%}
      <h2 class="dlh-pe__heading">
        {{ section.settings.desc_heading }}
        {%- if section.settings.desc_heading_accent != blank -%}
          <span class="dlh-pe__heading-accent">{{ section.settings.desc_heading_accent }}</span>
        {%- endif -%}
      </h2>
    {%- endif -%}

    <div class="dlh-pe__desc-grid">
      {%- comment -%} Left — rich text copy ── {%- endcomment -%}
      <div class="dlh-pe__copy">
        {{ section.settings.description }}
      </div>

      {%- comment -%} Right — included / not included card ── {%- endcomment -%}
      <aside class="dlh-pe__incl-card">
        {%- assign incl_yes = section.blocks | where: 'type', 'included' -%}
        {%- assign incl_no  = section.blocks | where: 'type', 'not_included' -%}

        {%- if incl_yes.size > 0 -%}
          <h5>What's included</h5>
          <ul class="dlh-pe__incl-list dlh-pe__incl-list--yes">
            {%- for block in incl_yes -%}
              <li {{ block.shopify_attributes }}>
                <svg width="16" height="16"><use href="#dlh-ico-check"/></svg>
                <span>{{ block.settings.text }}</span>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {%- if incl_no.size > 0 -%}
          <h5>Not included</h5>
          <ul class="dlh-pe__incl-list dlh-pe__incl-list--no">
            {%- for block in incl_no -%}
              <li {{ block.shopify_attributes }}>
                <svg width="16" height="16"><use href="#dlh-ico-x"/></svg>
                <span>{{ block.settings.text }}</span>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </aside>
    </div>
  </div>
</section>

{%- comment -%} ── Timeline (sand bg) ── {%- endcomment -%}
{%- assign timeline_blocks = section.blocks | where: 'type', 'timeline_step' -%}
{%- if timeline_blocks.size > 0 -%}
  <section class="dlh-pe__timeline-section" style="--dlh-pe-steps: {{ timeline_blocks.size }};">
    {%- if section.settings.tl_eyebrow != blank -%}
      <p class="dlh-pe__eyebrow">{{ section.settings.tl_eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.tl_heading != blank or section.settings.tl_heading_accent != blank -%}
      <h2 class="dlh-pe__heading">
        {{ section.settings.tl_heading }}
        {%- if section.settings.tl_heading_accent != blank -%}
          <span class="dlh-pe__heading-accent">{{ section.settings.tl_heading_accent }}</span>
        {%- endif -%}
      </h2>
    {%- endif -%}
    {%- if section.settings.tl_lede != blank -%}
      <p class="dlh-pe__lede">{{ section.settings.tl_lede }}</p>
    {%- endif -%}

    <div class="dlh-pe__timeline-wrap">
      <div class="dlh-pe__timeline-grid">
        {%- for block in timeline_blocks -%}
          <div class="dlh-pe__step" {{ block.shopify_attributes }}>
            <div class="dlh-pe__chip">
              <svg width="22" height="22"><use href="#dlh-ico-{{ block.settings.icon }}"/></svg>
            </div>
            <div class="dlh-pe__step-time">{{ block.settings.time_label }}</div>
            <div class="dlh-pe__step-name">{{ block.settings.name }}</div>
            <div class="dlh-pe__step-desc">{{ block.settings.description }}</div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
