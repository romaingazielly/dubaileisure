{{ 'timeline-steps.css' | asset_url | stylesheet_tag }}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} timeline-steps spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="timeline-steps__inner" style="--timeline-max-width: {{ section.settings.max_width }}px; --timeline-accent: {{ section.settings.accent_color }};">
    {% if section.settings.eyebrow != blank %}
      <p class="timeline-steps__eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h2 class="timeline-steps__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <p class="timeline-steps__subheading">{{ section.settings.subheading }}</p>
    {% endif %}

    <ol class="timeline-steps__list" role="list" style="--timeline-col-count: {{ section.blocks.size }};">
      {% for block in section.blocks %}
        <li class="timeline-steps__item" {{ block.shopify_attributes }}>
          <div class="timeline-steps__icon-wrapper" aria-hidden="true">
            {% if block.settings.icon_image != blank %}
              {{
                block.settings.icon_image
                | image_url: width: 120
                | image_tag:
                  widths: '40, 60, 80, 120',
                  sizes: '44px',
                  loading: 'lazy',
                  class: 'timeline-steps__icon-image',
                  alt: ''
              }}
            {% elsif block.settings.icon_name != 'none' %}
              <svg
                class="timeline-steps__icon-svg"
                focusable="false"
                aria-hidden="true"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 20 20"
                width="22"
                height="22"
              >
                {%- render 'icon', icon: block.settings.icon_name -%}
              </svg>
            {% else %}
              <span class="timeline-steps__icon-fallback">{{ forloop.index }}</span>
            {% endif %}
          </div>

          {% if block.settings.time_label != blank %}
            <p class="timeline-steps__time">{{ block.settings.time_label }}</p>
          {% endif %}

          {% if block.settings.title != blank %}
            <h3 class="timeline-steps__title">{{ block.settings.title }}</h3>
          {% endif %}

          {% if block.settings.description != blank %}
            <p class="timeline-steps__description">{{ block.settings.description }}</p>
          {% endif %}
        </li>
      {% endfor %}
    </ol>
  </div>
</div>

{% schema %}
{
  "name": "Timeline steps",
  "tag": "section",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Sur-titre",
      "default": "YOUR EVENING"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "What Actually Happens"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Sous-titre",
      "default": "6 heures. Un itineraire pense du pickup au drop-off."
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Couleur d'accent",
      "default": "#d7781a"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Largeur max du composant",
      "min": 900,
      "max": 1800,
      "step": 10,
      "unit": "px",
      "default": 1440
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Schema de couleurs",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Largeur section",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Pleine largeur" }
      ],
      "default": "full-width"
    },
    {
      "type": "header",
      "content": "Espacements"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Padding haut",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Padding bas",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Etape",
      "settings": [
        {
          "type": "text",
          "id": "time_label",
          "label": "Horaire",
          "default": "3:00 PM"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titre",
          "default": "Hotel Pickup"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "AC Land Cruiser, direct a la porte"
        },
        {
          "type": "header",
          "content": "Icone"
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Image icone (prioritaire)"
        },
        {
          "type": "select",
          "id": "icon_name",
          "label": "Icone SVG (si pas d'image)",
          "options": [
            { "value": "none", "label": "Aucune" },
            { "value": "truck", "label": "Truck" },
            { "value": "map_pin", "label": "Map pin" },
            { "value": "star", "label": "Star" },
            { "value": "leaf", "label": "Leaf" },
            { "value": "stopwatch", "label": "Stopwatch" },
            { "value": "serving_dish", "label": "Serving dish" },
            { "value": "silhouette", "label": "Silhouette" }
          ],
          "default": "map_pin"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Timeline steps",
      "blocks": [
        { "type": "step", "settings": { "time_label": "3:00 PM", "title": "Hotel Pickup", "description": "AC Land Cruiser, direct a la porte", "icon_name": "truck" } },
        { "type": "step", "settings": { "time_label": "4:00 PM", "title": "Dune Bashing", "description": "45 min dans les dunes rouges", "icon_name": "star" } },
        { "type": "step", "settings": { "time_label": "5:00 PM", "title": "Desert Activities", "description": "Sandboard, camel ride, falcon photo", "icon_name": "map_pin" } },
        { "type": "step", "settings": { "time_label": "6:30 PM", "title": "Sunset + BBQ", "description": "Buffet international et cafe arabe", "icon_name": "serving_dish" } },
        { "type": "step", "settings": { "time_label": "7:30 PM", "title": "Live Shows", "description": "Tanoura, belly dance, fire show", "icon_name": "silhouette" } },
        { "type": "step", "settings": { "time_label": "8:30 PM", "title": "Hotel Drop-off", "description": "Retour vers 9 PM", "icon_name": "map_pin" } }
      ]
    }
  ]
}
{% endschema %}
