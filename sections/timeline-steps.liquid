{{ 'timeline-steps.css' | asset_url | stylesheet_tag: preload: true }}

{%- liquid
  assign scheme = section.settings.color_scheme
  if scheme == blank
    assign scheme = 'scheme-5'
  endif
  assign layout = section.settings.heading_layout | default: 'split'
-%}

<div class="section-background color-{{ scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ scheme }} timeline-steps timeline-steps--layout-{{ layout }} spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div
    class="timeline-steps__inner"
    style="--timeline-max-width: {{ section.settings.max_width }}px; --timeline-accent: {{ section.settings.accent_color }};"
  >
    {% if section.settings.show_glow %}
      <span class="timeline-steps__glow timeline-steps__glow--tr" aria-hidden="true"></span>
      <span class="timeline-steps__glow timeline-steps__glow--bl" aria-hidden="true"></span>
    {% endif %}

    <div class="timeline-steps__header">
      <div class="timeline-steps__header-title">
        {% if section.settings.eyebrow != blank %}
          <p class="timeline-steps__eyebrow">
            <span class="timeline-steps__eyebrow-mark" aria-hidden="true"></span>
            {{ section.settings.eyebrow }}
          </p>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="timeline-steps__heading">
            {{ section.settings.heading }}{% if section.settings.heading_accent != blank %}<br><span class="timeline-steps__heading-accent">{{ section.settings.heading_accent }}</span>{% endif %}
          </h2>
        {% endif %}
      </div>
      {% if section.settings.subheading != blank %}
        <p class="timeline-steps__subheading">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    <ol class="timeline-steps__list" role="list">
      {% for block in section.blocks %}
        {%- liquid
          assign side = 'left'
          assign parity = forloop.index0 | modulo: 2
          if parity == 1
            assign side = 'right'
          endif
        -%}
        <li
          class="timeline-steps__item timeline-steps__item--{{ side }}"
          {{ block.shopify_attributes }}
        >
          <div class="timeline-steps__dot-wrapper">
            <div class="timeline-steps__dot" aria-hidden="true">
              {% if block.settings.show_icon and block.settings.icon_image != blank %}
                {{
                  block.settings.icon_image
                  | image_url: width: 60
                  | image_tag:
                    widths: '20, 30, 40, 60',
                    sizes: '22px',
                    loading: 'lazy',
                    class: 'timeline-steps__dot-icon',
                    alt: ''
                }}
              {% elsif block.settings.show_icon and block.settings.icon_name != 'none' %}
                <svg
                  class="timeline-steps__dot-icon"
                  focusable="false"
                  aria-hidden="true"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 20 20"
                  width="18"
                  height="18"
                >
                  {%- render 'icon', icon: block.settings.icon_name -%}
                </svg>
              {% else %}
                <span class="timeline-steps__dot-number">{{ forloop.index }}</span>
              {% endif %}
            </div>
          </div>
          <div class="timeline-steps__content">
            {% render 'timeline-step-content', block: block %}
          </div>
        </li>
      {% endfor %}
    </ol>
  </div>
</div>

{% schema %}
{
  "name": "Timeline steps",
  "tag": "section",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Sur-titre",
      "default": "YOUR EVENING · HOUR BY HOUR"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "What actually"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Titre accentue (2e ligne)",
      "info": "S'affiche sur une seconde ligne, dans la couleur d'accent.",
      "default": "happens."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Sous-titre",
      "default": "No vague desert experience marketing. Here is exactly what six hours with us looks like, from pickup to drop-off."
    },
    {
      "type": "select",
      "id": "heading_layout",
      "label": "Disposition de l'entete",
      "options": [
        { "value": "split", "label": "Titre a gauche, description a droite" },
        { "value": "stacked", "label": "Titre centre au-dessus" }
      ],
      "default": "split"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Couleur d'accent",
      "default": "#d7781a"
    },
    {
      "type": "checkbox",
      "id": "show_glow",
      "label": "Afficher les halos decoratifs",
      "info": "Deux halos radiaux ember et rouge en fond de section.",
      "default": true
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Largeur max du composant",
      "min": 900,
      "max": 1800,
      "step": 10,
      "unit": "px",
      "default": 1440
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Schema de couleurs",
      "default": "scheme-5"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Largeur section",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Pleine largeur" }
      ],
      "default": "full-width"
    },
    {
      "type": "header",
      "content": "Espacements"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Padding haut",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Padding bas",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 96
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Etape",
      "settings": [
        {
          "type": "text",
          "id": "time_label",
          "label": "Horaire",
          "default": "3:00 PM"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titre",
          "default": "Hotel Pickup"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "AC Land Cruiser, direct a la porte"
        },
        {
          "type": "header",
          "content": "Icone (optionnel)"
        },
        {
          "type": "checkbox",
          "id": "show_icon",
          "label": "Afficher l'icone a la place du numero",
          "default": false
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Image icone (prioritaire)"
        },
        {
          "type": "select",
          "id": "icon_name",
          "label": "Icone SVG (si pas d'image)",
          "options": [
            { "value": "none", "label": "Aucune" },
            { "value": "truck", "label": "Truck" },
            { "value": "map_pin", "label": "Map pin" },
            { "value": "star", "label": "Star" },
            { "value": "leaf", "label": "Leaf" },
            { "value": "stopwatch", "label": "Stopwatch" },
            { "value": "serving_dish", "label": "Serving dish" },
            { "value": "silhouette", "label": "Silhouette" }
          ],
          "default": "map_pin"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Timeline steps",
      "blocks": [
        { "type": "step", "settings": { "time_label": "3:00 PM", "title": "Hotel Pickup", "description": "AC Land Cruiser, direct a la porte", "icon_name": "truck" } },
        { "type": "step", "settings": { "time_label": "4:00 PM", "title": "Desert Activities", "description": "Quad, sandboard, camel ride, falcon photo", "icon_name": "stopwatch" } },
        { "type": "step", "settings": { "time_label": "5:00 PM", "title": "Dune Bashing", "description": "30 min dans les dunes rouges", "icon_name": "map_pin" } },
        { "type": "step", "settings": { "time_label": "6:30 PM", "title": "Sunset + BBQ", "description": "Buffet international, lanternes arabes", "icon_name": "serving_dish" } },
        { "type": "step", "settings": { "time_label": "7:30 PM", "title": "Live Shows", "description": "Tanoura, belly dance, fire show", "icon_name": "silhouette" } },
        { "type": "step", "settings": { "time_label": "8:30 PM", "title": "Hotel Drop-off", "description": "Retour vers 9 PM", "icon_name": "map_pin" } }
      ]
    }
  ]
}
{% endschema %}
