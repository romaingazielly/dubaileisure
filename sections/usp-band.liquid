{{ 'usp.css' | asset_url | stylesheet_tag }}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} usp-band spacing-style"
  style="
    {% render 'spacing-style', settings: section.settings %}
    --usp-max-width: {{ section.settings.max_width }}px;
    --usp-gap: {{ section.settings.gap }}px;
    --usp-radius: {{ section.settings.cell_radius }}px;
    --usp-logo-h: {{ section.settings.logo_max_height }}px;
    --usp-card-min-height: {{ section.settings.card_min_height }}px;
  "
>
  <div class="usp-band__inner" {{ section.shopify_attributes }}>
    <div class="usp-band__blocks">
      {% content_for 'blocks' %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "USP",
  "tag": "section",
  "class": "section-wrapper",
  "max_blocks": 50,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "range",
      "id": "max_width",
      "label": "Largeur max du contenu",
      "min": 900,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Espacement entre les blocs",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16,
      "info": "S’applique entre les blocs de la section, et entre les cartes USP à l’intérieur d’un groupe (ligne ou colonne)."
    },
    {
      "type": "range",
      "id": "cell_radius",
      "label": "Arrondi des cartes USP",
      "min": 8,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 18,
      "info": "S’applique à toutes les cartes USP de cette section."
    },
    {
      "type": "range",
      "id": "logo_max_height",
      "label": "Hauteur max des logos (cartes USP)",
      "min": 28,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 44,
      "info": "S’applique à toutes les cartes USP de cette section."
    },
    {
      "type": "range",
      "id": "card_min_height",
      "label": "Hauteur min. des cartes (uniforme)",
      "min": 100,
      "max": 260,
      "step": 4,
      "unit": "px",
      "default": 152,
      "info": "Toutes les cartes USP ont au moins cette hauteur. En ligne, elles s’alignent sur la plus haute."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Schéma de couleurs",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Largeur de section",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Pleine largeur" }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "Espacements"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Padding haut",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Padding bas",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "usp_cell"
    },
    {
      "type": "group"
    },
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "USP",
      "category": "t:categories.storytelling",
      "blocks": [
        {
          "type": "usp_cell",
          "settings": {
            "heading": "Family safe",
            "caption": "Ages 3 to 80+"
          }
        },
        {
          "type": "usp_cell",
          "settings": {
            "heading": "Eco-conscious",
            "caption": "Sustainable tourism"
          }
        },
        {
          "type": "usp_cell",
          "settings": {
            "heading": "Premium quality",
            "caption": "Top-tier hospitality"
          }
        },
        {
          "type": "usp_cell",
          "settings": {
            "heading": "ISO certified",
            "caption": "Quality management"
          }
        }
      ]
    }
  ]
}
{% endschema %}
