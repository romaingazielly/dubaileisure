{{ 'dlh-experience-grid.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign collection = section.settings.collection
  assign max_products = section.settings.max_products
-%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} dlh-exp spacing-style"
  style="
    {% render 'spacing-style', settings: section.settings %}
    --dlh-exp-max-w: {{ section.settings.max_width }}px;
  "
>
  <div class="dlh-exp__inner">
    <div
      class="dlh-exp__header{% if section.settings.subheading != blank %} dlh-exp__header--split{% endif %}"
      {{ section.shopify_attributes }}
    >
      <div class="dlh-exp__header-title">
        {% if section.settings.eyebrow != blank %}
          <p class="dlh-exp__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {% endif %}
        {% if section.settings.heading != blank or section.settings.heading_accent != blank %}
          <h2 class="dlh-exp__heading">
            {% if section.settings.heading != blank %}{{ section.settings.heading | escape }}{% endif %}
            {% if section.settings.heading_accent != blank %}
              <span class="dlh-exp__heading-accent"> {{ section.settings.heading_accent | escape }}</span>
            {% endif %}
          </h2>
        {% endif %}
      </div>
      {% if section.settings.subheading != blank %}
        <p class="dlh-exp__sub">{{ section.settings.subheading | escape }}</p>
      {% endif %}
    </div>
  </div>

  <div class="dlh-exp__scroll-wrap">
    <div class="dlh-exp__grid">
      {% if collection != blank and collection.products_count > 0 %}
        {% for product in collection.products limit: max_products %}
          {% render 'dlh-experience-card', product: product, section_settings: section.settings %}
        {% endfor %}
      {% else %}
        {% for i in (1..max_products) %}
          {% render 'dlh-experience-card', product: null, section_settings: section.settings %}
        {% endfor %}
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Experience grid",
  "tag": "section",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Our Experiences"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Pick your"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Heading accent",
      "default": "adventure"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Four curated ways to experience the Arabian desert. Every trip includes hotel pickup, Bedouin-led guiding, and complimentary Gahwa."
    },
    {
      "type": "header",
      "content": "Products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "max_products",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "Max products",
      "default": 4
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max content width",
      "info": "Same role as Timeline: title block and product row share this width.",
      "min": 900,
      "max": 1800,
      "step": 10,
      "unit": "px",
      "default": 1440
    },
    {
      "type": "header",
      "content": "Display"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show rating pill",
      "info": "Uses product metafield reviews.rating or falls back to 4.9",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_tags",
      "label": "Show product tags as pills",
      "info": "Displays tags that don't start with badge: or meta:",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "full-width"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 96
    }
  ],
  "presets": [
    {
      "name": "Experience grid",
      "category": "t:categories.collection"
    }
  ]
}
{% endschema %}
