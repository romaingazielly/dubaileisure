{% render 'guest-review-card', block: block, show_shopify_attributes: true %}

{% schema %}
{
  "name": "Guest review",
  "tag": null,
  "settings": [
    {
      "type": "range",
      "id": "rating",
      "min": 1,
      "max": 5,
      "step": 1,
      "label": "Rating",
      "default": 5
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Quote",
      "default": "Absolutely spectacular evening. The dune bashing was thrilling, the buffet was outstanding, and the fire show had our kids speechless."
    },
    {
      "type": "text",
      "id": "author",
      "label": "Name",
      "default": "James M."
    },
    {
      "type": "text",
      "id": "meta",
      "label": "Secondary line",
      "info": "e.g. city and review source",
      "default": "London, UK · TripAdvisor"
    },
    {
      "type": "text",
      "id": "avatar_initials",
      "label": "Avatar initials",
      "info": "Optional — generated from the name when empty"
    }
  ],
  "presets": [
    {
      "name": "Guest review",
      "category": "t:categories.storytelling",
      "settings": {
        "quote": "Absolutely spectacular evening. The dune bashing was thrilling, the buffet was outstanding, and the fire show had our kids speechless.",
        "author": "James M.",
        "meta": "London, UK · TripAdvisor"
      }
    }
  ]
}
{% endschema %}
